# Copy to .env and fill in from Supabase Project Settings → API.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Same public key as backend VAPID_PUBLIC_KEY — enables push subscribe after onboarding
# VITE_VAPID_PUBLIC_KEY=

# Optional — backend URL if you proxy push subscribe through Express instead of Supabase insert
# VITE_BACKEND_URL=http://localhost:3001

# Optional — Replit sets these; local dev defaults to PORT=5173 and BASE_PATH=/
# PORT=5173
# BASE_PATH=/
